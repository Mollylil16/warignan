# API : en local, laisser vide pour utiliser le proxy Vite `/api`.
# En production (frontend et API sur domaines différents) : URL complète, ex. https://api.tondomaine.com/api
# Promotions publiques : GET {VITE_API_BASE_URL}/promotions/active
VITE_API_BASE_URL=

# Lien marchand Wave (page de paiement). Les liens pay.wave.com/m/... sont utilisés tels quels.
VITE_WAVE_PAY_URL=https://pay.wave.com/m/M_aYjQD9O9E8ld/c/ci/
# Orange Money (optionnel) : URL de ta page ou deep link marchand
VITE_ORANGE_MONEY_PAY_URL=
