# API backend (obligatoire en prod). Ex. http://localhost:4000/api
# Promotions publiques : GET {VITE_API_BASE_URL}/promotions/active
VITE_API_BASE_URL=

# Liens de redirection paiement (page marchande Wave / Orange Money ou passerelle).
# Exemple : https://pay.wave.com/m/TON_ID ou URL fournie par ton intégration.
# Les paramètres amount, ref et flow sont ajoutés en query si l’URL le permet.
VITE_WAVE_PAY_URL=
VITE_ORANGE_MONEY_PAY_URL=
