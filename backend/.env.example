DATABASE_URL="file:./dev.db"
# Doit correspondre au proxy Vite (frontend/src) : 4000 par défaut
PORT=4000
NODE_ENV=development
JWT_SECRET=change-moi-en-production-tres-long-et-aleatoire
# Origine du site Vite en local (port 3000)
CORS_ORIGIN=http://localhost:3000

# Webhooks (exercice collègue : vérifier les signatures)
WAVE_WEBHOOK_SECRET=
ORANGE_MONEY_WEBHOOK_SECRET=

# Dossier upload local (exercice : migrer vers S3)
UPLOAD_DIR=./uploads
