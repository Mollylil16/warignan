{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "declaration": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true
  },
  "include": [
    "src/index.ts",
    "src/app.ts",
    "src/config/env.ts",
    "src/lib/pagination.ts",
    "src/lib/prisma.ts",
    "src/lib/webhookSignature.ts",
    "src/middleware/**/*.ts",
    "src/routes/auth.ts",
    "src/routes/deliveries.ts",
    "src/routes/dashboard.ts",
    "src/routes/health.ts",
    "src/routes/media.ts",
    "src/routes/orders.ts",
    "src/routes/payments.ts",
    "src/routes/products.ts",
    "src/routes/promotions.ts",
    "src/routes/reservations.ts",
    "src/routes/tracking.ts",
    "src/routes/users.ts",
    "src/routes/webhooks.ts",
    "src/services/**/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
